<!-- Forward a request to the backend with
timeouts, retries and concurrency limit.
Depends on named values
- limit-concurrency-key
- limit-concurrency-max-count
- retry-count
- retry-interval
- retry-max-interval
- retry-delta
- forward-request-timeout -->
<fragment>
  <limit-concurrency key="{{limit-concurrency-key}}"
    max-count="{{limit-concurrency-max-count}}">
    <retry
      condition="@(context.Response.StatusCode == 503)"
      count="{{retry-count}}"
      interval="1"
      max-interval="100"
      delta="{{retry-delta}}"
      first-fast-retry="false">
      <forward-request
        http-version="2or1"
        timeout="{{forward-request-timeout}}"
        follow-redirects="false"
        buffer-request-body="true"
        buffer-response="true"
        fail-on-error-status-code="true" />
    </retry>
  </limit-concurrency>
</fragment>