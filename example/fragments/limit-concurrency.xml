<!-- Depends on named values limit-concurrency-key forward-request-timeout
limit-concurrency-max-count -->
<fragment>
  <limit-concurrency key="{{limit-concurrency-key}}" max-count="{{limit-concurrency-max-count}}">
    <forward-request
      http-version="2or1"
      timeout="{{forward-request-timeout}}"
      follow-redirects="false"
      buffer-request-body="true"
      buffer-response="true"
      fail-on-error-status-code="true" />
  </limit-concurrency>
</fragment>